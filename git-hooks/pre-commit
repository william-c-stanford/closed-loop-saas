#!/bin/sh
# context-gardening pre-commit hook
# Runs fast local doc structure checks before every commit.
# Installed by /context-gardening:init

LINTERS_DIR="$(git rev-parse --show-toplevel)/.garden/linters"

if [ ! -f "$LINTERS_DIR/run-all.js" ]; then
  echo "context-gardening: linters not installed. Run /context-gardening:init to set up."
  exit 0
fi

node "$LINTERS_DIR/run-all.js" --pre-commit
